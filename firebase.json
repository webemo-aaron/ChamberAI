{
  "projects": {
    "dev": "chamberai-dev",
    "staging": "chamberai-staging",
    "prod": "chamberai-prod"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    {
      "bucket": "chamberai-dev.appspot.com",
      "rules": "storage.rules",
      "target": "dev"
    },
    {
      "bucket": "chamberai-staging.appspot.com",
      "rules": "storage.rules",
      "target": "staging"
    },
    {
      "bucket": "chamberai-prod.appspot.com",
      "rules": "storage.rules",
      "target": "prod"
    }
  ],
  "emulators": {
    "auth": {
      "host": "127.0.0.1",
