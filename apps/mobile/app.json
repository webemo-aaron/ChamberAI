{
  "expo": {
    "name": "ChamberAI",
    "slug": "chamberai-mobile",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.chamberai.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1f2937"
      },
      "package": "com.chamberai.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#1f2937",
      "sounds": []
    }
  }
}
