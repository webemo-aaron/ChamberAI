# Hybrid low-cost deployment profile (single VPS + static frontend)
# Copy to .env.hybrid on your VPS and edit values.

COMPOSE_PROJECT_NAME=chamberofcommerceai

# Public API host (served by Caddy)
API_DOMAIN=api.example.org
ACME_EMAIL=ops@example.org

# App runtime
API_PORT=8080
API_NODE_ENV=production
WORKER_PORT=8080
WORKER_NODE_ENV=production

# Firebase emulator profile
GCP_PROJECT_ID=cam-aim-dev
FIREBASE_AUTH_ENABLED=true
FIREBASE_USE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=firebase-emulators:8080
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulators:9099
FIREBASE_STORAGE_EMULATOR_HOST=firebase-emulators:9199

# Storage
GCS_BUCKET_NAME=chamberofcommerceai-local-audio

# Frontend origin for CORS (Cloudflare Pages / GitHub Pages URL)
CORS_ORIGIN=https://your-frontend.pages.dev

# Worker callback endpoint
WORKER_ENDPOINT=http://worker:8080/tasks/process

# Stripe billing (required for checkout, portal, webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_COUNCIL=price_...
STRIPE_PRICE_NETWORK=price_...
APP_BASE_URL=https://your-frontend.pages.dev

# Multi-tenancy
DEFAULT_ORG_ID=default
