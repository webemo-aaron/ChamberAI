# Hybrid low-cost deployment profile (single VPS + static frontend)
# Copy to .env.hybrid on your VPS and edit values.

COMPOSE_PROJECT_NAME=chamberofcommerceai

# Public domains (served by Caddy with auto-HTTPS via Let's Encrypt)
# Example: api.chamberai.mahoosuc.ai, app.chamberai.mahoosuc.ai
API_DOMAIN=api.example.org
APP_DOMAIN=app.example.org
ACME_EMAIL=ops@example.org

# App runtime
API_PORT=8080
API_NODE_ENV=production
WORKER_PORT=8080
WORKER_NODE_ENV=production

# Deployment mode: Set DEMO_MODE=true during initial deployment (before Stripe is configured)
# This allows free tier to create real meetings for testing/demo purposes
# Once Stripe is configured and billing is live, set to false or remove
DEMO_MODE=false

# Firebase emulator profile
GCP_PROJECT_ID=cam-aim-dev
FIREBASE_AUTH_ENABLED=true
FIREBASE_USE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=firebase-emulators:8080
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulators:9099
FIREBASE_STORAGE_EMULATOR_HOST=firebase-emulators:9199

# Storage
GCS_BUCKET_NAME=chamberofcommerceai-local-audio

# Frontend origin for CORS and redirects
CORS_ORIGIN=https://app.example.org

# Worker callback endpoint
WORKER_ENDPOINT=http://worker:8080/tasks/process

# Frontend URL (for API redirects, Stripe success URLs, etc.)
API_BASE=https://api.example.org

# Stripe billing (required for checkout, portal, webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_COUNCIL=price_...
STRIPE_PRICE_COUNCIL_ANNUAL=price_...
STRIPE_PRICE_NETWORK=price_...
APP_BASE_URL=https://app.example.org

# Multi-tenancy
DEFAULT_ORG_ID=default

# Admin bootstrap (email of first admin user - will be created on first auth)
AUTH_BOOTSTRAP_ADMINS=admin@chamber.example.org

# Require membership verification for auth
FIREBASE_REQUIRE_MEMBERSHIP=true
