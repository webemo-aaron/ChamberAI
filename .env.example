# Docker Compose overrides (optional)
# Copy to .env and edit to customize docker-compose values.

# Compose project name (controls network/volume prefixes)
COMPOSE_PROJECT_NAME=chamberofcommerceai

# API service
API_PORT=8080
API_NODE_ENV=development

# Worker service
WORKER_PORT=8080
WORKER_NODE_ENV=development

# Firebase / GCP
GCP_PROJECT_ID=chamberofcommerceai-local
FIREBASE_AUTH_ENABLED=true
FIREBASE_USE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=firebase-emulators:8080
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulators:9099
FIREBASE_STORAGE_EMULATOR_HOST=firebase-emulators:9199

# Storage
GCS_BUCKET_NAME=chamberofcommerceai-local-audio

# CORS
CORS_ORIGIN=http://127.0.0.1:5173

# Worker callback endpoint
WORKER_ENDPOINT=http://worker:8080/tasks/process

# Stripe billing (required for checkout, portal, webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_COUNCIL=price_...
STRIPE_PRICE_NETWORK=price_...
APP_BASE_URL=http://localhost:5173

# Multi-tenancy
DEFAULT_ORG_ID=default
